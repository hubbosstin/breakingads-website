/*
  # Clickjacking protection - prevent the site being embedded in iframes on other domains
  X-Frame-Options: SAMEORIGIN

  # Prevent MIME type sniffing - browser must use declared content-type
  X-Content-Type-Options: nosniff

  # XSS protection header (legacy browsers)
  X-XSS-Protection: 1; mode=block

  # Control referrer information sent with requests
  Referrer-Policy: strict-origin-when-cross-origin

  # Restrict browser APIs available to the page
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()

  # HSTS - force HTTPS for 1 year, include subdomains
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Content Security Policy
  # - default: only same origin
  # - scripts: same origin only (no external JS)
  # - styles: same origin + Google Fonts
  # - fonts: same origin + Google Fonts CDN
  # - images: same origin + Unsplash (for insights hero) + breakingads CDN
  # - connect: same origin only (Netlify forms POST)
  # - frame: none
  # - object: none (no Flash, plugins)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://images.unsplash.com; connect-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';

  # Remove server fingerprinting
  X-Powered-By: 

  # Cache control for HTML pages - revalidate each visit
  Cache-Control: no-cache, must-revalidate

/img/*
  # Cache images aggressively - they don't change often
  Cache-Control: public, max-age=31536000, immutable

/styles.css
  # Cache CSS for 7 days
  Cache-Control: public, max-age=604800

/favicon*
  Cache-Control: public, max-age=31536000, immutable
